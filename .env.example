# Spotify Developer App (https://developer.spotify.com/dashboard)
# Redirect URI must be exactly: http://localhost:3000/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Supabase Postgres — Transaction mode (port 6543), NOT Session mode (5432)
# Format: postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Supabase project URL + anon key (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=

# Better-Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
